<Window x:Class="MonitorPonto.Views.AlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitor de Ponto"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="True"
        Background="Transparent">

    <Grid x:Name="GridRoot">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="800">

            <TextBlock x:Name="TxtIcon"
                       FontFamily="Segoe UI Emoji" FontSize="90"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock x:Name="TxtTitulo"
                       FontFamily="Segoe UI" FontSize="36" FontWeight="Bold"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock x:Name="TxtSubtitulo"
                       FontFamily="Segoe UI" FontSize="16" Foreground="#CCCCCC"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock x:Name="TxtNome"
                       FontFamily="Segoe UI" FontSize="20" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <TextBlock x:Name="TxtInfo1"
                       FontFamily="Segoe UI" FontSize="17" Foreground="#A8DADC"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <TextBlock x:Name="TxtInfo2"
                       FontFamily="Segoe UI" FontSize="17" Foreground="#A8DADC"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <TextBlock x:Name="TxtAgora"
                       FontFamily="Segoe UI" FontSize="17" Foreground="#F4A261"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <TextBlock x:Name="TxtCountdown"
                       FontFamily="Segoe UI" FontSize="13" Foreground="#888888"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Button x:Name="BtnOk"
                    FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                    Foreground="White" Padding="40,18" BorderThickness="0"
                    Cursor="Hand" HorizontalAlignment="Center"
                    Click="BtnOk_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</Window>
