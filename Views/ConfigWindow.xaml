<Window x:Class="MonitorPonto.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitor de Ponto — Configurações"
        Width="520" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>

        <!-- Label padrão -->
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2d2d2d"/>
            <Setter Property="Padding" Value="0,4,0,2"/>
        </Style>

        <!-- TextBox padrão -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- PasswordBox padrão -->
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- CheckBox padrão -->
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <!-- Botão primário -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1a3a5c"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2d6a9f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cabeçalho de seção -->
        <Style x:Key="SecHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2d6a9f"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="#1a3a5c" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏰" FontSize="22" Foreground="White"
                           FontFamily="Segoe UI Emoji" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Monitor de Ponto" FontFamily="Segoe UI" FontSize="16"
                               FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Configurações" FontFamily="Segoe UI"
                               FontSize="12" Foreground="#A8C8E8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Abas -->
        <TabControl Grid.Row="1" Margin="0" Background="#F5F7FA"
                    BorderThickness="0">

            <!-- ═══ ABA: MEUS DADOS ═══ -->
            <TabItem Header="👤  Meus Dados" FontFamily="Segoe UI" FontSize="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16,20,16">

                        <TextBlock Text="CONTA RHID" Style="{StaticResource SecHeader}"/>

                        <Label Content="E-mail de login"/>
                        <TextBox x:Name="TxtUsername"/>

                        <Label Content="Senha" Margin="0,8,0,0"/>
                        <PasswordBox x:Name="TxtPassword"/>

                        <Label Content="Domínio" Margin="0,8,0,0"/>
                        <TextBox x:Name="TxtDomain"/>

                        <TextBlock Text="IDENTIFICAÇÃO" Style="{StaticResource SecHeader}"/>

                        <Label Content="Seu nome completo"/>
                        <TextBox x:Name="TxtNome"/>

                        <Label Content="Seu ID no RHiD (id_person)" Margin="0,8,0,0"/>
                        <TextBox x:Name="TxtIdPerson"/>
                        <TextBlock Text="💡 Para descobrir: abra o RHiD no navegador, pressione F12, vá em Network e clique em Registrar Ponto. Procure a requisição ponto_diario e veja o campo idPerson na resposta."
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#888888"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ ABA: HORÁRIOS ═══ -->
            <TabItem Header="🕐  Horários" FontFamily="Segoe UI" FontSize="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16,20,16">

                        <!-- ENTRADA -->
                        <TextBlock Text="ENTRADA" Style="{StaticResource SecHeader}"/>
                        <CheckBox x:Name="ChkEntradaEnabled" Content="Monitorar entrada"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Horário previsto"/>
                                <TextBox x:Name="TxtEntradaHorario"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Label Content=""/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Aviso (min antes)"/>
                                <TextBox x:Name="TxtEntradaAntec"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Label Content="Urgente (min depois)"/>
                                <TextBox x:Name="TxtEntradaToler"/>
                            </StackPanel>
                        </Grid>

                        <!-- ALMOÇO -->
                        <TextBlock Text="ALMOÇO" Style="{StaticResource SecHeader}"/>
                        <CheckBox x:Name="ChkAlmocoEnabled" Content="Monitorar almoço"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Janela início"/>
                                <TextBox x:Name="TxtAlmocoJanelaIni"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Label Content="Janela fim"/>
                                <TextBox x:Name="TxtAlmocoJanelaFim"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Duração (min)"/>
                                <TextBox x:Name="TxtAlmocoDuracao"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <Label Content="Aviso (min antes)"/>
                                <TextBox x:Name="TxtAlmocoAntec"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Urgente (min depois)"/>
                                <TextBox x:Name="TxtAlmocoToler"/>
                            </StackPanel>
                        </Grid>

                        <!-- SAÍDA -->
                        <TextBlock Text="SAÍDA" Style="{StaticResource SecHeader}"/>
                        <CheckBox x:Name="ChkSaidaEnabled" Content="Monitorar saída"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Horário previsto"/>
                                <TextBox x:Name="TxtSaidaHorario"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Label Content=""/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Aviso (min antes)"/>
                                <TextBox x:Name="TxtSaidaAntec"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Label Content="Urgente (min depois)"/>
                                <TextBox x:Name="TxtSaidaToler"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ ABA: CONFIGURAÇÕES ═══ -->
            <TabItem Header="⚙️  Avançado" FontFamily="Segoe UI" FontSize="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16,20,16">

                        <TextBlock Text="HORÁRIO DE FUNCIONAMENTO" Style="{StaticResource SecHeader}"/>
                        <TextBlock Text="O monitor só ficará ativo neste intervalo."
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Início"/>
                                <TextBox x:Name="TxtHorarioIni"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Label Content="Fim"/>
                                <TextBox x:Name="TxtHorarioFim"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="POLLING" Style="{StaticResource SecHeader}"/>
                        <TextBlock Text="Com que frequência o sistema consulta o RHiD."
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#888888" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Intervalo normal (seg)"/>
                                <TextBox x:Name="TxtPollingNormal"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <Label Content="Intervalo próximo (seg)"/>
                                <TextBox x:Name="TxtPollingProximo"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Janela próxima (min)"/>
                                <TextBox x:Name="TxtJanela"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="TESTAR ALERTAS" Style="{StaticResource SecHeader}"/>
                        <TextBlock Text="Clique para ver como os alertas aparecem na tela."
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#888888" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Button Style="{StaticResource BtnSecondary}" Content="🌅 Entrada Aviso"
                                    Margin="0,0,8,8" Click="TesteEntradaAviso_Click"/>
                            <Button Style="{StaticResource BtnSecondary}" Content="🚨 Entrada Urgente"
                                    Margin="0,0,8,8" Click="TesteEntradaUrgente_Click"/>
                            <Button Style="{StaticResource BtnSecondary}" Content="⏰ Almoço Aviso"
                                    Margin="0,0,8,8" Click="TesteAlmocoAviso_Click"/>
                            <Button Style="{StaticResource BtnSecondary}" Content="🚨 Almoço Urgente"
                                    Margin="0,0,8,8" Click="TesteAlmocoUrgente_Click"/>
                            <Button Style="{StaticResource BtnSecondary}" Content="🌆 Saída Aviso"
                                    Margin="0,0,8,8" Click="TesteSaidaAviso_Click"/>
                            <Button Style="{StaticResource BtnSecondary}" Content="🚨 Saída Urgente"
                                    Margin="0,0,0,8" Click="TesteSaidaUrgente_Click"/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Rodapé com botões -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <DockPanel>
                <TextBlock x:Name="TxtStatus"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#888888"
                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource BtnSecondary}" Content="Cancelar"
                            Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                    <Button Style="{StaticResource BtnPrimary}" Content="💾  Salvar"
                            Click="BtnSalvar_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
